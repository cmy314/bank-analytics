# 复制本文件为 .env 后填写路径（不要将 .env 提交到 Git）

# ============ Alibaba microservices v2021 ============
MSRT_PATH=E:/data/MSRTQps_0.csv
MS_RESOURCE_PATH=E:/data/MSResource_0.csv

# 多分片模式：CSV 目录（含 MSRTQps_0.csv、MSRTQps_1.csv … 与配对 MSResource_N.csv）
# DATA_DIR_V2021=E:/data/alibaba-v2021

# 输出目录（默认可不设，会使用 analytics/output/v2021）
# OUTPUT_DIR_V2021=E:/output/v2021

# 多分片命令默认分片列表（run_v2021_shards.py / v2021-shards）
# V2021_SHARDS=0,1,2

# 仅调试：限制读取 MSRT 行数，留空表示读全文件
# MSRT_NROWS=500000
# MS_RESOURCE_NROWS=2000000

# true=只用调用量最大的一个 msname（省内存）；false=全表（内存很大）
# ONLY_FIRST_MSNAME=true

# 跨分片固定同一微服务/实例（见 docs/多分片固定服务实验.md）
# MSNAME_FILTER=
# MSINSTANCEID_FILTER=

# IF_CONTAMINATION=0.02

# ============ 短窗容量预测（QPS 驱动，默认开启） ============
# CAPACITY_ENABLED=true
# CAPACITY_CPU_THRESHOLD=0.7
# CAPACITY_MEMORY_THRESHOLD=0.8

# 可选：短观测窗上的 Prophet 演示（非主线，Windows 可能装不上 prophet）
# TRY_PROPHET_V2021=false
